[Unit]
Description=Ethnomusicology Next.js Frontend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/ethnomusicology/frontend-next
ExecStart=/home/ubuntu/.bun/bin/bun --bun next start -p 3000
Restart=on-failure
RestartSec=10s
StandardOutput=journal
StandardError=journal
Environment=NODE_ENV=production
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
